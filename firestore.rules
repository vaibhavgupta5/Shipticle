rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Multi-tenant: user must be authenticated, and their uid must match the userId field on the document.
    function isOwner() {
      return request.auth != null && request.auth.uid == resource.data.userId;
    }

    function isCreatingWithOwner() {
      return request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // ── ideas ────────────────────────────────────────────────────────────
    match /ideas/{ideaId} {
      allow read, update, delete: if isOwner();
      allow create: if isCreatingWithOwner();
    }

    // ── articles ─────────────────────────────────────────────────────────
    match /articles/{articleId} {
      allow read, update, delete: if isOwner();
      allow create: if isCreatingWithOwner();
    }

    // ── publications ──────────────────────────────────────────────────────
    match /publications/{pubId} {
      allow read, update, delete: if isOwner();
      allow create: if isCreatingWithOwner();
    }

    // ── promptTemplates ───────────────────────────────────────────────────
    match /promptTemplates/{templateId} {
      allow read, update, delete: if isOwner();
      allow create: if isCreatingWithOwner();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
